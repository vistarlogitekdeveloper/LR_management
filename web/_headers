/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# Content-hashed / version-pinned assets — safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/canvaskit/*
  Cache-Control: public, max-age=31536000, immutable

# App icons + favicon keep the SAME name across deploys but their contents can
# change on a rebrand, so they must revalidate — otherwise a returning browser
# keeps the old icon forever (the same trap the entry files below avoid).
/icons/*
  Cache-Control: public, max-age=0, must-revalidate

/favicon.png
  Cache-Control: public, max-age=0, must-revalidate

# Flutter's entry files keep the SAME name every build but their contents change
# on each deploy. They MUST always revalidate, otherwise a returning browser
# serves the old bundle and never picks up a new deployment. (Do NOT cache these
# immutable — that was the bug that pinned the app to an old version.)
/index.html
  Cache-Control: public, max-age=0, must-revalidate

/flutter_bootstrap.js
  Cache-Control: public, max-age=0, must-revalidate

/flutter_service_worker.js
  Cache-Control: public, max-age=0, must-revalidate

/main.dart.js
  Cache-Control: public, max-age=0, must-revalidate

/flutter.js
  Cache-Control: public, max-age=0, must-revalidate

/version.json
  Cache-Control: public, max-age=0, must-revalidate
